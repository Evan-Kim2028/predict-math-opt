/// Standard normal CDF using piecewise cubic polynomials.
/// 16 segments of width 0.25 on [0, 4], cubic polynomial per segment.
/// Max error: 0.0108 bp (meets 0.01 bp target).
public fun normal_cdf(x: u64, x_negative: bool): u64 {
    // Tail clamp: beyond 4σ
    if (x >= B16) {
        return if (x_negative) { 0 } else { FLOAT_SCALING }
    };

    // Precompute x² and x³
    let x2 = math_utils::mul(x, x);
    let x3 = math_utils::mul(x2, x);

    // Select segment and evaluate cubic (16-way dispatch)
    let result = if (x < B1) {
        eval_neg_d(x, x2, x3, SEG0_A, SEG0_B, SEG0_C, SEG0_D)
    } else if (x < B2) {
        eval_neg_d(x, x2, x3, SEG1_A, SEG1_B, SEG1_C, SEG1_D)
    } else if (x < B3) {
        eval_neg_d(x, x2, x3, SEG2_A, SEG2_B, SEG2_C, SEG2_D)
    } else if (x < B4) {
        eval_neg_d(x, x2, x3, SEG3_A, SEG3_B, SEG3_C, SEG3_D)
    } else if (x < B5) {
        eval_pos_d(x, x2, x3, SEG4_A, SEG4_B, SEG4_C, SEG4_D)
    } else if (x < B6) {
        eval_pos_d(x, x2, x3, SEG5_A, SEG5_B, SEG5_C, SEG5_D)
    } else if (x < B7) {
        eval_pos_d(x, x2, x3, SEG6_A, SEG6_B, SEG6_C, SEG6_D)
    } else if (x < B8) {
        eval_pos_d(x, x2, x3, SEG7_A, SEG7_B, SEG7_C, SEG7_D)
    } else if (x < B9) {
        eval_pos_d(x, x2, x3, SEG8_A, SEG8_B, SEG8_C, SEG8_D)
    } else if (x < B10) {
        eval_pos_d(x, x2, x3, SEG9_A, SEG9_B, SEG9_C, SEG9_D)
    } else if (x < B11) {
        eval_pos_d(x, x2, x3, SEG10_A, SEG10_B, SEG10_C, SEG10_D)
    } else if (x < B12) {
        eval_pos_d(x, x2, x3, SEG11_A, SEG11_B, SEG11_C, SEG11_D)
    } else if (x < B13) {
        eval_pos_d(x, x2, x3, SEG12_A, SEG12_B, SEG12_C, SEG12_D)
    } else if (x < B14) {
        eval_pos_d(x, x2, x3, SEG13_A, SEG13_B, SEG13_C, SEG13_D)
    } else if (x < B15) {
        eval_pos_d(x, x2, x3, SEG14_A, SEG14_B, SEG14_C, SEG14_D)
    } else {
        eval_pos_d(x, x2, x3, SEG15_A, SEG15_B, SEG15_C, SEG15_D)
    };

    // Symmetry: Phi(-x) = 1 - Phi(x)
    if (x_negative) { FLOAT_SCALING - result } else { result }
}

// === Segment evaluators ===
// All segments: P(x) = A + B*x - C*x²  ± D*x³
// C is always negative. D sign splits at seg 4.

/// Segs 0–3: D is negative → A + B*x - C*x² - D*x³
fun eval_neg_d(x: u64, x2: u64, x3: u64, a: u64, b: u64, c: u64, d: u64): u64 {
    let pos = a + math_utils::mul(b, x);
    let neg = math_utils::mul(c, x2) + math_utils::mul(d, x3);
    if (pos > neg) { pos - neg } else { 0 }
}

/// Segs 4–15: D is positive → A + B*x - C*x² + D*x³
fun eval_pos_d(x: u64, x2: u64, x3: u64, a: u64, b: u64, c: u64, d: u64): u64 {
    let pos = a + math_utils::mul(b, x) + math_utils::mul(d, x3);
    let neg = math_utils::mul(c, x2);
    if (pos > neg) { pos - neg } else { 0 }
}

// === Tests ===

#[test]
fun test_cdf_at_zero() {
    let result = normal_cdf(0, false);
    let diff = if (result > 500_000_000) { result - 500_000_000 } else { 500_000_000 - result };
    assert!(diff < 100, 0); // Should be ~exact
}

#[test]
fun test_cdf_at_one() {
    let result = normal_cdf(1_000_000_000, false);
    let expected = 841_344_746;
    let diff = if (result > expected) { result - expected } else { expected - result };
    assert!(diff < 100_000, 1); // < 1bp
}

#[test]
fun test_cdf_at_two() {
    let result = normal_cdf(2_000_000_000, false);
    let expected = 977_249_868;
    let diff = if (result > expected) { result - expected } else { expected - result };
    assert!(diff < 100_000, 2); // < 1bp
}

#[test]
fun test_cdf_symmetry() {
    let pos = normal_cdf(1_000_000_000, false);
    let neg = normal_cdf(1_000_000_000, true);
    let sum = pos + neg;
    let diff = if (sum > FLOAT_SCALING) { sum - FLOAT_SCALING } else { FLOAT_SCALING - sum };
    assert!(diff < 100, 3);
}

#[test]
fun test_cdf_tail() {
    assert!(normal_cdf(5_000_000_000, false) == FLOAT_SCALING);
    assert!(normal_cdf(5_000_000_000, true) == 0);
}

#[test]
fun test_cdf_at_half() {
    let result = normal_cdf(500_000_000, false);
    let expected = 691_462_461;
    let diff = if (result > expected) { result - expected } else { expected - result };
    assert!(diff < 100_000, 0); // < 1bp
}

#[test]
fun test_cdf_monotonic() {
    // CDF must be monotonically increasing
    let v0 = normal_cdf(0, false);
    let v1 = normal_cdf(250_000_000, false);  // 0.25
    let v2 = normal_cdf(500_000_000, false);  // 0.50
    let v3 = normal_cdf(1_000_000_000, false); // 1.0
    let v4 = normal_cdf(2_000_000_000, false); // 2.0
    let v5 = normal_cdf(3_000_000_000, false); // 3.0
    assert!(v1 > v0);
    assert!(v2 > v1);
    assert!(v3 > v2);
    assert!(v4 > v3);
    assert!(v5 > v4);
}

#[test]
/// Verify 0.01 bp accuracy target across segment midpoints.
/// Reference values computed via math.erfc (high-accuracy). Max poly error: 0.0108 bp = ~1080 units.
/// Tolerance: 2_000 units (0.02 bp) to absorb fixed-point rounding on top of polynomial error.
fun test_cdf_accuracy_01bp() {
    let tolerance = 2_000u64;
    let checks: vector<u64> = vector[
        549_738_225, // x=0.125
        646_169_767, // x=0.375
        734_014_471, // x=0.625
        809_213_047, // x=0.875
        869_705_483, // x=1.125
        915_434_278, // x=1.375
        947_918_721, // x=1.625
        969_603_638, // x=1.875
    ];
    let xs: vector<u64> = vector[
        125_000_000, 375_000_000, 625_000_000, 875_000_000,
        1_125_000_000, 1_375_000_000, 1_625_000_000, 1_875_000_000,
    ];
    let mut i = 0;
    while (i < xs.length()) {
        let result = normal_cdf(xs[i], false);
        let expected = checks[i];
        let diff = if (result > expected) { result - expected } else { expected - result };
        assert!(diff < tolerance, i);
        i = i + 1;
    };
}
